# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Storage
UPLOAD_DIR=uploads
STORAGE_DIR=storage

# Database
DATABASE_URL=sqlite:///./course_agent.db

# Default mode
DEFAULT_REPORT_MODE=standard

# Model selection
QUICK_TEXT_PROVIDER=deepseek
QUICK_TEXT_MODEL=DeepSeek-V3.2

STANDARD_TEXT_PROVIDER=deepseek
STANDARD_TEXT_MODEL=DeepSeek-V3.2

VISUAL_TEXT_PROVIDER=deepseek
VISUAL_TEXT_MODEL=DeepSeek-V3.2
VISUAL_VISION_PROVIDER=kimi
VISUAL_VISION_MODEL=Kimi-K2.5

ADVANCED_PROVIDER=kimi
ADVANCED_MODEL=Kimi-K2.5

REVIEW_PROVIDER=glm
REVIEW_MODEL=GLM-4.7

CHAT_PROVIDER=deepseek
CHAT_MODEL=DeepSeek-V3.2

ADVANCED_CHAT_PROVIDER=gemini
ADVANCED_CHAT_MODEL=gemini-2.5-pro

PAGE_JUDGE_PROVIDER=kimi
PAGE_JUDGE_MODEL=Kimi-K2.5

LLM_TIMEOUT_SECONDS=120

# API keys
OPENAI_COMPATIBLE_API_KEY=your_api_key
OPENAI_COMPATIBLE_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1

ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_BASE_URL=https://modelservice.jdcloud.com/coding/anthropic

DEEPSEEK_API_KEY=your_api_key
DEEPSEEK_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1

GLM_API_KEY=your_api_key
GLM_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1

KIMI_API_KEY=your_api_key
KIMI_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1

GEMINI_API_KEY=your_api_key
GEMINI_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1

QWEN_API_KEY=your_api_key
QWEN_BASE_URL=https://modelservice.jdcloud.com/coding/openai/v1
